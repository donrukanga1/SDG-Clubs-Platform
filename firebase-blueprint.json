{
  "entities": {
    "club": {
      "title": "Club Profile",
      "description": "Schema definition for an SDG club chapter profile in Uganda.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "institution": { "type": "string" },
        "level": { "type": "string" },
        "region": { "type": "string" },
        "score": { "type": "number" },
        "members": { "type": "number" },
        "sdgFocus": { "type": "string" },
        "leader": { "type": "string" },
        "bio": { "type": "string" },
        "email": { "type": "string" },
        "lastActive": { "type": "string" },
        "leaders": { "type": "string" },
        "patron": { "type": "string" },
        "membersList": { "type": "string" },
        "mission": { "type": "string" },
        "achievements": { "type": "string" },
        "subscribed": { "type": "boolean" },
        "credits": { "type": "number" },
        "geminiLinked": { "type": "boolean" },
        "downloadCount": { "type": "number" },
        "passcode": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "name", "institution", "level", "region", "score", "members", "sdgFocus"]
    },
    "course": {
      "title": "Curriculum Course Module",
      "description": "A dynamic curriculum course module containing lessons and quiz assessments managed by the SDG administrator.",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "color": { "type": "string" },
        "content": { "type": "array" },
        "quiz": { "type": "array" }
      },
      "required": ["id", "title", "summary", "color", "content", "quiz"]
    },
    "loungeMessage": {
      "title": "Lounge Chat Message",
      "description": "Represents messages or posts generated by certified SDG club chapters inside the Lounge board.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clubName": { "type": "string" },
        "region": { "type": "string" },
        "level": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string" },
        "likes": { "type": "number" }
      },
      "required": ["id", "clubName", "text"]
    }
  },
  "firestore": {
    "/clubs/{clubId}": {
      "schema": "club",
      "description": "Collection of all registered Youth Coalition for SDGs club chapters in Uganda."
    },
    "/courses/{courseId}": {
      "schema": "course",
      "description": "Pedagogical chapters/courses with active quiz evaluations."
    },
    "/loungeMessages/{msgId}": {
      "schema": "loungeMessage",
      "description": "The dynamic timeline of lounge conversations and actions shouted by different chapters."
    }
  }
}
